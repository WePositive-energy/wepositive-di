# ── Async wrappers depending on sync providers (non-coroutine result path) ──


@pytest.mark.skip_wire
async def test_async_gen_depends_on_sync_provider() -> None:
    """Async generator provider whose dependency is a sync provider.

    Covers branch 139->141 in async_gen_wrapper: the sync provider returns a
    plain value (not a coroutine), so the iscoroutine check evaluates to False.
    """

    @register_provider()
    def sync_base() -> int:
        return 100

    @register_provider(context_manager=True)
    @asynccontextmanager
    async def gen_with_sync_dep(
        val: int = Depends[sync_base],
    ) -> AsyncGenerator[int, None]:
        yield val * 2

    @inject
    async def consumer(result: int = Depends[gen_with_sync_dep]) -> int:
        return result

    assert await consumer() == 200
    clear_overrides()


@pytest.mark.skip_wire
async def test_async_func_depends_on_sync_provider() -> None:
    """Async function provider whose dependency is a sync provider.

    Covers branch 162->164 in async_func_wrapper.
    """

    @register_provider()
    def sync_base() -> str:
        return "world"

    @register_provider()
    async def func_with_sync_dep(label: str = Depends[sync_base]) -> str:
        return f"hello {label}"

    @inject
    async def consumer(result: str = Depends[func_with_sync_dep]) -> str:
        return result

    assert await consumer() == "hello world"
    clear_overrides()


@pytest.mark.skip_wire
def test_inject_on_decorator() -> None:
    """Test that @inject can decorate a decorator so dependencies are injected into it.

    When Python applies @add_prefix to greet, it calls add_prefix(greet). The
    @inject wrapper intercepts this, binds func=greet, resolves
    Depends[prefix_provider] → "hello", then calls the real add_prefix with
    both arguments.  No parentheses needed at the call site.
    """

    @register_provider()
    def prefix_provider() -> str:
        return "hello"

    @inject
    def add_prefix(
        func: Callable[..., str], prefix: str = Depends[prefix_provider]
    ) -> Callable[..., str]:
        def wrapper(*args: Any, **kwargs: Any) -> str:
            return f"{prefix}_{func(*args, **kwargs)}"

        return wrapper

    @add_prefix
    def greet(name: str) -> str:
        return name

    assert greet("world") == "hello_world"
    clear_overrides()


@pytest.mark.skip_wire
async def test_provider_returns_callable_with_own_dependencies() -> None:
    """Provider returns a callable that closes over its own resolved dependencies.

    Verifies that:
    - A provider can return a callable (e.g. a factory or partial).
    - The dependent receives and can invoke that callable.
    - The provider's own Depends are resolved before the callable is returned,
      so those resolved values are available inside the callable.
    """

    @register_provider()
    async def multiplier() -> int:
        return 3

    @register_provider()
    async def make_multiply(factor: int = Depends[multiplier]) -> Callable[[int], int]:
        def multiply(value: int) -> int:
            return value * factor

        return multiply

    @inject
    async def consumer(fn: Callable[[int], int] = Depends[make_multiply]) -> int:
        return fn(7)

    setup()
    try:
        assert await consumer() == 21
    finally:
        clear_overrides()
