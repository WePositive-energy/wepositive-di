@pytest.mark.skip_wire
async def test_inject_with_override_path() -> None:
    """Test inject decorator resolves overridden provider via _provider_overrides."""

    @register_provider()
    async def original() -> int:
        return 100

    async def override() -> int:
        return 999

    @inject
    async def consumer(value: int = Depends[original]) -> int:
        return value

    with provider_overrides({original: override}):
        assert await consumer() == 999

    clear_overrides()


# ── Override path inside provider wrappers ────────────────────────────────────


@pytest.mark.skip_wire
async def test_async_func_wrapper_resolves_overridden_dep() -> None:
    """Override active when async func provider resolves its own dependency.

    Covers line 159 in async_func_wrapper: the _provider_overrides path is taken
    when a dependency of an async function provider is overridden.
    """

    @register_provider()
    async def base() -> int:
        return 1

    async def overridden_base() -> int:
        return 50

    @register_provider()
    async def doubled(val: int = Depends[base]) -> int:
        return val * 2

    @inject
    async def consumer(result: int = Depends[doubled]) -> int:
        return result

    with provider_overrides({base: overridden_base}):
        assert await consumer() == 100  # 50 * 2

    clear_overrides()


@pytest.mark.skip_wire
def test_sync_func_wrapper_resolves_overridden_dep() -> None:
    """Override active when sync func provider resolves its own dependency.

    Covers line 222 in sync_wrapper.
    """

    @register_provider()
    def base() -> int:
        return 1

    def overridden_base() -> int:
        return 7

    @register_provider()
    def tripled(val: int = Depends[base]) -> int:
        return val * 3

    @inject
    def consumer(result: int = Depends[tripled]) -> int:
        return result

    with provider_overrides({base: overridden_base}):
        assert consumer() == 21  # 7 * 3

    clear_overrides()


# ── @override_provider used as a decorator ────────────────────────────────────


@pytest.mark.skip_wire
async def test_override_provider_decorator_syntax() -> None:
    """@override_provider(original) used as a decorator.

    Covers lines 321-325: the inner decorator function is returned and applied.
    """

    @register_provider()
    async def original() -> str:
        return "original"

    @override_provider(original)
    async def replacement() -> str:  # type: ignore[reportUnusedFunction]
        return "decorated_override"

    @inject
    async def consumer(val: str = Depends[original]) -> str:
        return val

    setup()
    try:
        assert await consumer() == "decorated_override"
    finally:
        clear_overrides()
