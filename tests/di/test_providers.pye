# ── Provider wrappers: non-Depends parameter (False branch of isinstance check) ──


@pytest.mark.skip_wire
async def test_async_gen_provider_with_non_depends_param() -> None:
    """Async gen provider with a plain-default param alongside a Depends param.

    Covers the False branch of isinstance(value, _DependsMarker) in async_gen_wrapper
    (branch 134->132): the loop skips non-Depends params and leaves them at their defaults.
    """

    @register_provider()
    async def base() -> int:
        return 5

    @register_provider(context_manager=True)
    @asynccontextmanager
    async def gen_mixed(
        multiplier: int = 3,  # plain default, not Depends
        val: int = Depends[base],
    ) -> AsyncGenerator[int, None]:
        yield val * multiplier

    @inject
    async def consumer(result: int = Depends[gen_mixed]) -> int:
        return result

    assert await consumer() == 15
    clear_overrides()


