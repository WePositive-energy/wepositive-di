@pytest.mark.skip_wire
async def test_async_gen_with_multiple_dependencies() -> None:
    """Test async generator with multiple Depends params."""

    @register_provider()
    async def dep1() -> int:
        return 10

    @register_provider()
    async def dep2() -> int:
        return 20

    @register_provider(context_manager=True)
    @asynccontextmanager
    async def gen_with_multiple_deps(
        val1: int = Depends[dep1], val2: int = Depends[dep2]
    ) -> AsyncGenerator[int, None]:
        try:
            yield val1 + val2
        finally:
            pass

    @inject
    async def consumer(value: int = Depends[gen_with_multiple_deps]) -> int:
        return value

    result = await consumer()
    assert result == 30

    clear_overrides()


